# MySQL
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=tbank_service
MYSQL_PASSWORD=
MYSQL_DATABASE=tbank_invoicing

# Google Sheets (только чтение для синка)
GOOGLE_SHEET_URL=
# Имя вкладки с контрагентами в том же документе Google Sheets
GOOGLE_COUNTERPARTIES_SHEET_NAME=Контрагенты
GOOGLE_CREDENTIALS_PATH=credentials/google_service_account.json

# T-Bank
TBANK_API_URL=https://business.tbank.ru/openapi/api/v1
TBANK_TOKEN=
# Для крона выписки/оплат: список расчетных счетов через запятую/пробел
TBANK_STATEMENT_ACCOUNT_NUMBERS=
# Первый запуск крона выплат: глубина начальной загрузки выписки (дни)
TBANK_STATEMENT_INITIAL_LOOKBACK_DAYS=90
# Перекрытие окна синка на каждом запуске (минуты), чтобы не терять операции
TBANK_STATEMENT_OVERLAP_MINUTES=180
# Размер страницы GET /statement (1..200)
TBANK_STATEMENT_PAGE_LIMIT=200
# Лимит необработанных входящих операций на один запуск матчинга
TBANK_STATEMENT_UNMATCHED_LIMIT=5000
# Опционально: если задан, все счета отправляются на этот email (debug)
DEBUG_FORCE_EMAIL=

# Напоминания об оплате счетов клиентам (отдельный email-канал)
# Смещения в днях после due_date, когда отправлять напоминания
INVOICE_REMINDER_OFFSETS_DAYS=3,7,10,14
# Лимит счетов-кандидатов на один запуск reminder-cron
INVOICE_REMINDER_LIMIT=5000

# SMTP для клиентских email-напоминаний
INVOICE_REMINDER_EMAIL_SMTP_HOST=
INVOICE_REMINDER_EMAIL_SMTP_PORT=587
INVOICE_REMINDER_EMAIL_SMTP_USER=
INVOICE_REMINDER_EMAIL_SMTP_PASSWORD=
INVOICE_REMINDER_EMAIL_SMTP_USE_TLS=true
INVOICE_REMINDER_EMAIL_SMTP_USE_SSL=false
INVOICE_REMINDER_EMAIL_SMTP_TIMEOUT_SEC=20
INVOICE_REMINDER_EMAIL_SMTP_DEBUG=false
INVOICE_REMINDER_EMAIL_FROM=
INVOICE_REMINDER_EMAIL_FROM_NAME=
# Если true, reminder и thank-you письма дублируются скрытой копией на INVOICE_REMINDER_EMAIL_FROM
INVOICE_REMINDER_EMAIL_COPY_TO_FROM=false
# Опционально: имя получателя в заголовке To
INVOICE_REMINDER_EMAIL_TO_NAME=
INVOICE_REMINDER_EMAIL_REPLY_TO=

# Bitrix24 (импорт контрагентов + задачи)
# Можно указать:
# - базовый webhook URL: https://<portal>.bitrix24.ru/rest/<user_id>/<code>
# - или полный URL метода: .../crm.company.add.json
BITRIX24_WEBHOOK_URL=
# Отдельный webhook для создания задач в cron (tasks.task.add)
# Можно указать базовый URL или полный URL метода: .../tasks.task.add.json
BITRIX24_TASK_WEBHOOK_URL=
# Отдельный webhook для создания сделок и товарных позиций (crm.deal.add, crm.deal.productrows.set)
# Можно указать базовый URL или полный URL метода: .../crm.deal.add.json
BITRIX24_DEAL_WEBHOOK_URL=
# Задержка между запросами импорта (секунды)
BITRIX24_IMPORT_DELAY_SEC=0.35
# Опциональные коды пользовательских полей компании (например UF_CRM_123...)
# Рекомендуется задать хотя бы INN и/или SHORT_NAME для надёжного дедупа при повторных запусках
BITRIX24_COMPANY_SHORT_NAME_FIELD=
BITRIX24_COMPANY_INN_FIELD=
BITRIX24_COMPANY_KPP_FIELD=
BITRIX24_COMPANY_NOTE_FIELD=
BITRIX24_COMPANY_INVOICE_SCHEDULE_FIELD=
# Реквизиты организации (crm.requisite.*)
# Если preset не задан, скрипт выберет активный preset по стране (по умолчанию РФ=1)
BITRIX24_REQUISITE_PRESET_ID=
BITRIX24_REQUISITE_COUNTRY_ID=1

# Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_ACCOUNTANTS_CHAT_ID=

# MAX
MAX_BOT_TOKEN=
MAX_ACCOUNTANTS_CHAT_ID=

# Invoice selection
# 0/false (default): нижняя граница даты не применяется
# 1/true: строгий период по invoice_schedule (monthly/2weeks/10days/daily)
INVOICE_STRICT_PERIOD=false
# Логировать количество невыставленных работ до начала strict-периода
INVOICE_WARN_OUT_OF_PERIOD=true
